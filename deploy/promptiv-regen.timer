[Unit]
Description=Regenerate Promptiv static content daily (after the nightly price refresh)

[Timer]
# 14:00 UTC: the 07:00 refresh (~5-6h) is well finished, and it's before the
# Sunday 15:00 UTC digest, so hub pages reflect fresh fares.
OnCalendar=*-*-* 14:00:00 UTC
Persistent=true
RandomizedDelaySec=300

[Install]
WantedBy=timers.target
